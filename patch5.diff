+                                                    Just gm -> do
+                                                        let lm = Chess.Board.mkLegalMove gm
+                                                        let givesCheck = KingSafety.givesCheckOptimized (pieces board) (state board) dcBitboard gm
+
+                                                        score <- case applyLegalMoveValidated vBoard lm givesCheck of
